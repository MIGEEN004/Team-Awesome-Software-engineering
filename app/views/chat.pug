extends Layout

block content
    .main-content
        h1 Chat regarding Game Tip ##{gameId}
        p Messaging User ID: #{receiverId}
        
        .chat-box(style="background: #fdfdfd; border: 1px solid #ddd; padding: 15px; height: 400px; overflow-y: scroll; border-radius: 8px;")
            if messages && messages.length > 0
                each msg in messages
                    div(style=msg.sender_id == currentUserId ? "text-align: right; margin-bottom: 15px;" : "text-align: left; margin-bottom: 15px;")
                        div(style=msg.sender_id == currentUserId ? "background: #007bff; color: white; display: inline-block; padding: 10px 15px; border-radius: 15px 15px 0 15px;" : "background: #f1f0f0; color: #333; display: inline-block; padding: 10px 15px; border-radius: 15px 15px 15px 0;")
                            strong= msg.sender_id == currentUserId ? "You: " : "Author: "
                            span= msg.message_text
                            br
                            small(style="font-size: 0.7em; opacity: 0.8;")= msg.created_at
            else
                p.text-muted No messages yet. Start the conversation by asking a question!

        form(action="/send-message" method="POST" style="margin-top: 20px; display: flex; flex-direction: column;")
            input(type="hidden" name="receiverId" value=receiverId)
            input(type="hidden" name="gameId" value=gameId)
            textarea(name="message_text" placeholder="Ask a question about this tip..." required style="width: 100%; height: 80px; padding: 10px; border-radius: 4px; border: 1px solid #ccc; resize: none;")
            button.btn.btn-primary(type="submit" style="margin-top: 10px; align-self: flex-end; padding: 10px 25px;") Send Question