extends Layout

block content
    .main-content
        h1 Public Forum for Game ##{gameId}

        //- CRUD: Search (Read Filter)
        form(method="GET" action=`/chat/${gameId}` style="margin-bottom: 20px; display: flex; gap: 10px;")
            input(type="text" name="search" placeholder="Search forum posts..." value=searchQuery style="flex-grow: 1; padding: 8px; border-radius: 4px; border: 1px solid #ccc;")
            button.btn.btn-secondary(type="submit" style="padding: 8px 15px;") Search
            if searchQuery
                a.btn.btn-outline(href=`/chat/${gameId}` style="padding: 8px; text-decoration: none; border: 1px solid #ccc; border-radius: 4px;") Clear

        .chat-box(style="background: #fdfdfd; border: 1px solid #ddd; padding: 15px; height: 400px; overflow-y: scroll; border-radius: 8px;")
            if messages && messages.length > 0
                each msg in messages
                    div(style=msg.sender_id == currentUserId ? "text-align: right; margin-bottom: 15px;" : "text-align: left; margin-bottom: 15px;")
                        div(style=msg.sender_id == currentUserId ? "background: #007bff; color: white; display: inline-block; padding: 10px 15px; border-radius: 15px 15px 0 15px; position: relative;" : "background: #f1f0f0; color: #333; display: inline-block; padding: 10px 15px; border-radius: 15px 15px 15px 0; position: relative;")
                            strong User ##{msg.sender_id}: 
                            span= msg.message_text
                            br
                            small(style="font-size: 0.7em; opacity: 0.8;")= msg.created_at
                            
                            //- CRUD: Delete (Only show if it's the user's own message)
                            if msg.sender_id == currentUserId
                                form(method="POST" action=`/delete-message/${msg.MessageID || msg.id}` style="display:inline; margin-left: 10px;")
                                    input(type="hidden" name="gameId" value=gameId)
                                    button(type="submit" style="background:none; border:none; color: #ff4d4d; cursor:pointer; font-size: 0.8em;") [Delete]
            else
                p.text-muted No posts yet. Be the first to start the discussion!

        //- CRUD: Create
        form(action="/send-message" method="POST" style="margin-top: 20px; display: flex; flex-direction: column;")
            input(type="hidden" name="gameId" value=gameId)
            textarea(name="message_text" placeholder="Write a public comment..." required style="width: 100%; height: 80px; padding: 10px; border-radius: 4px; border: 1px solid #ccc; resize: none;")
            button.btn.btn-primary(type="submit" style="margin-top: 10px; align-self: flex-end; padding: 10px 25px;") Post to Forum