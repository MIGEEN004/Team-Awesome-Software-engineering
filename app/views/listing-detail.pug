extends Layout

block content
  .container
    h1= game.Title
    hr
    .row
      .col-md-6
        //- Placeholder for game image
        img(src="/images/logo.png" alt=game.Title style="width:100%; max-width:400px;")
      .col-md-6
        h3 Description
        p= game.Description
        h4 Price: £#{game.Price}
        
        hr
        h5 Community Exchange Info
        p Seller: 
          a(href=`/user-profile/${game.User_ID}`) View Seller Profile
        
        button.btn.btn-primary Contact Seller for Exchange
    
    h3 Leave a Tip & Rating
form(action='/rate-listing' method='POST')
  input(type='hidden' name='listingId' value=listing.id)
  div
    label(for='rating') Rating (1-5):
    select(name='rating' id='rating')
      each val in [1, 2, 3, 4, 5]
        option(value=val)= val
  div
    label(for='comment') Your Tip:
    textarea(name='comment' id='comment' placeholder='Share your experience...')
  button(type='submit') Submit Feedback

    