extends layout

block content
  .search-results-page
    h1 Search Results for "#{query}"

    //- 1. Games Results Section
    section.results-section
      h2 🎮 Games Found (#{gameResults.length})
      hr
      if gameResults.length > 0
        .listing-container
          each game in gameResults
            .game-card
              .card-left
                .cover-container
                  img(src=`/images/covers/${game.id}.jpg` alt=game.title class="game-cover-img" onerror="this.src='/images/default-cover.png'")
              .card-mid
                h2: a(href='/game/' + game.id)= game.title
                p.description= game.description
              .card-right
                .metadata
                  p: strong Score: #{game.metacritic_score || 'N/A'}
                  p: strong Year: #{game.release_year}
      else
        p.no-results No games matched your search.

    //- 2. Posts Results Section
    section.results-section
      h2 📝 Posts Found (#{postResults.length})
      hr
      if postResults.length > 0
        .posts-container
          each post in postResults
            .post-card
              .card-left
                .circle-avatar #{post.username.charAt(0).toUpperCase()}
              .card-mid
                h2: a(href='/post/' + post.id)= post.title
                p.post-username Posted by: #{post.username}
              .card-right
                .metadata
                  p: strong Flair: #{post.flair || 'General'}
                  p: strong Date: #{post.post_timestamp.toISOString().split('T')[0]}
      else
        p.no-results No posts matched your search.