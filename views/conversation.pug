extends layout

block content
  .chat-container(style="max-width: 600px; margin: 0 auto; background: #fff; border: 3px solid #000; display: flex; flex-direction: column; height: 70vh;")
    
    .chat-header(style="padding: 15px; background: var(--primary-blue); color: white; border-bottom: 3px solid var(--accent-orange);")
      h2(style="margin: 0;") Chat with #{otherUser.nickname}

    .chat-history(style="flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; background: #fafafa;")
      if chat && chat.length > 0
        each msg in chat
          //- Determine if the message is from the logged-in user or the other person
          - const isMine = msg.sender_id == currentUser.id
          
          .chat-bubble-wrapper(style=`display: flex; ${isMine ? 'justify-content: flex-end;' : 'justify-content: flex-start;'}`)
            .chat-bubble(style=`max-width: 70%; padding: 10px 15px; border-radius: 8px; border: 2px solid #000; ${isMine ? 'background: #e0f7fa;' : 'background: #fff;'}`)
              p(style="margin: 0;") #{msg.message_text}
              span(style="display: block; font-size: 0.7rem; color: #888; margin-top: 5px; text-align: right;") #{msg.sent_at.toString().split(' ')[4]}
      else
        p(style="text-align: center; color: #888;") No messages yet. Say hi!

    .chat-input-area(style="padding: 15px; border-top: 2px solid #ccc; background: #fff;")
      form(action=`/messages/${otherUserId}` method="POST" style="display: flex; gap: 10px;")
        input(type="text" name="message_text" placeholder="Type a message..." required autocomplete="off" style="flex: 1; padding: 10px; border: 2px solid #ccc; border-radius: 4px;")
        button(type="submit" style="padding: 10px 20px; background: var(--primary-blue); color: white; font-weight: bold; border: 2px solid #000; cursor: pointer;") Send