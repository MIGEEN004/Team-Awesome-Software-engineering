extends layout

block content
  .post-page-layout
    .author-nickname
     a(href=`/user/${post.user_id}`)= post.nickname

    .post-header-row
      .title-box
        h1= post.title

      .meta-stack
        p ЁЯП╖я╕П #{post.Flair_Name || 'General'}
        p ЁЯОо #{post.game_name}
        p ЁЯТ╗ #{post.platform_name}
        p ЁЯУЕ #{post.post_timestamp.toString().split(' GMT')[0]}

    //- NEW: Post Management (Only for the author)
    if currentUser && currentUser.id == post.user_id
      .post-management-controls
        a.btn-edit(href=`/post/${post.id}/edit`) тЬПя╕П Edit Post
        form(action=`/post/${post.id}/delete` method="POST" onsubmit="return confirm('Are you sure you want to delete this post?')")
          button.btn-delete(type="submit") ЁЯЧСя╕П Delete Post

    .description-box
      h4 Post description:
      p.description-text= post.description

    .rating-row
      .rating-box
        strong Total Stars: 
        span= post.total_rating
      
      if currentUser
        .rating-form-box
          form(action=`/post/${post.id}/rate` method="POST")
            button.star-button(type="submit") тнР Star this Post

    .comments-container
      h3 Community Discussion
      hr

      if currentUser
        .add-comment-box
          h4 Leave a Comment (as #{currentUser.nickname})
          form(action=`/post/${post.id}/comment` method="POST")
            textarea.comment-textarea(name="comment_text" rows="3" placeholder="Write your thoughts here..." required)
            button(type="submit") Post Comment
            
      hr

      if comments && comments.length > 0
        each comment in comments
          .comment-block
            .comment-content
              strong
              a(href=`/user/${comment.user_id}`)= comment.nickname
              span.timestamp  тАФ #{comment.comment_timestamp.toString().split(' GMT')[0]}
              p(id=`text-${comment.id}`)= comment.comment_text
              
              //- NEW: Comment Management (Edit/Delete)
              if currentUser && currentUser.id == comment.user_id
                .comment-actions
                  button.btn-tiny(onclick=`toggleEditComment(${comment.id})`) Edit
                  form(action=`/comment/${comment.id}/delete` method="POST" style="display:inline;")
                    input(type="hidden" name="postId" value=post.id)
                    button.btn-tiny.btn-danger(type="submit") Delete

                //- Hidden inline edit form
                form(id=`edit-form-${comment.id}` action=`/comment/${comment.id}/edit` method="POST" style="display:none; margin-top: 10px;")
                  input(type="hidden" name="postId" value=post.id)
                  textarea.comment-textarea(name="comment_text")= comment.comment_text
                  button(type="submit") Update
                  button(type="button" onclick=`toggleEditComment(${comment.id})`) Cancel
            
            if replies && replies.some(r => r.comment_id == comment.id)
              .replies-list
                each reply in replies
                  if reply.comment_id == comment.id
                    .reply-item
                      strong
                      a(href=`/user/${reply.user_id}`)= reply.nickname
                      span.timestamp  тАФ #{reply.reply_timestamp.toString().split(' GMT')[0]}
                      p= reply.reply_text
                      
            if currentUser
              .add-reply-box
                form(action=`/comment/${comment.id}/reply` method="POST")
                  input(type="hidden" name="postId" value=post.id)
                  textarea.reply-textarea(name="reply_text" rows="2" placeholder="Write a reply..." required)
                  button(type="submit") Reply
      else
        p.no-comments No thoughts yet. Be the first to comment!

  //- Script to toggle the comment edit form visibility
  script.
    function toggleEditComment(commentId) {
      const form = document.getElementById('edit-form-' + commentId);
      const text = document.getElementById('text-' + commentId);
      if (form.style.display === 'none') {
        form.style.display = 'block';
        text.style.display = 'none';
      } else {
        form.style.display = 'none';
        text.style.display = 'block';
      }
    }