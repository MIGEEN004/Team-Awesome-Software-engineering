extends layout

block content
  .profile-container
    //- Top Section: Profile Header
    .profile-header
      .profile-pic
        .circle-avatar
          span= user.full_name.charAt(0)
      
      .profile-bio
        if user.bio
          p= user.bio
        else
          p No bio provided.
        
        //- NEW: Bio Editing (Only show if it's the user's own profile)
        if currentUser && currentUser.id == user.id
          button.btn-edit-bio(onclick="document.getElementById('edit-bio-form').style.display='block'") Edit Bio
          
          form#edit-bio-form(action="/profile/edit" method="POST")
            textarea(name="bio" rows="3")= user.bio
            .form-actions
              button(type="submit") Save Changes
              button(type="button" onclick="document.getElementById('edit-bio-form').style.display='none'") Cancel
        
        //- Messaging Button (Only show if it's not their own profile)
        if currentUser && currentUser.id != user.id
          a.btn-message(href=`/messages/${user.id}`) Send Message
          
      .profile-info
        p 
          strong Member Since: 
          | #{new Date(user.date_joined).toLocaleDateString()}
        p 
          strong Email: 
          | #{user.email}

    //- Bottom Section: User Posts
    .profile-posts-section
      .posts-header
        h3 User Posts

      .posts-list
        if posts && posts.length > 0
          each post in posts
            .post-card
              .post-left
                h4
                  a(href=`/post/${post.id}`)= post.title
                p.post-date= new Date(post.post_timestamp).toLocaleDateString()
              
              .post-right
                p.post-flair Post flair: #{post.Flair_Name || 'General'}
        else
          p.no-posts This user hasn't posted anything yet.